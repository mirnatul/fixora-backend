model User {
    id        String       @id @default(uuid())
    name      String
    email     String       @unique
    password  String
    role      Role         @default(CUSTOMER)
    status    ActiveStatus @default(ACTIVE)
    createdAt DateTime     @default(now())
    updatedAt DateTime     @updatedAt
}

enum Role {
    CUSTOMER
    TECHNICIAN
    ADMIN
}

enum ActiveStatus {
    ACTIVE
    BANNED
}
